---
source: src/config.rs
expression: schema
---
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawConfig",
  "type": "object",
  "properties": {
    "devop": {
      "$ref": "#/$defs/ConfigDevOp"
    },
    "kioyu": {
      "$ref": "#/$defs/ConfigKioyu",
      "default": {
        "max_retries": 1,
        "memory": 1024
      }
    },
    "runners": {
      "$ref": "#/$defs/RawConfigRunner"
    },
    "server": {
      "$ref": "#/$defs/ConfigServer",
      "default": {
        "port": 8787
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "devop",
    "runners"
  ],
  "$defs": {
    "ConfigDevOp": {
      "type": "object",
      "properties": {
        "allowed_repositories": {
          "$ref": "#/$defs/OneOrMany(string,PreferOne)"
        },
        "allowed_users": {
          "$ref": "#/$defs/OneOrMany(string,PreferOne)"
        },
        "token": {
          "type": "string"
        },
        "vendor": {
          "$ref": "#/$defs/Vendor"
        },
        "webhook_secret": {
          "type": "string"
        }
      },
      "required": [
        "vendor",
        "token",
        "webhook_secret",
        "allowed_repositories",
        "allowed_users"
      ]
    },
    "ConfigKioyu": {
      "type": "object",
      "properties": {
        "max_retries": {
          "type": "integer",
          "format": "uint",
          "default": 1,
          "minimum": 0
        },
        "memory": {
          "type": "integer",
          "format": "uint32",
          "default": 1024,
          "minimum": 0
        }
      }
    },
    "ConfigServer": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "format": "uint16",
          "default": 8787,
          "maximum": 65535,
          "minimum": 1
        }
      }
    },
    "OneOrMany(string,PreferOne)": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "RawConfigRunner": {
      "type": "object",
      "properties": {
        "cpus": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 1
        },
        "envs": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "memory": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 1
        },
        "ports": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "integer",
            "format": "uint16",
            "maximum": 65535,
            "minimum": 0
          },
          "default": null
        },
        "secrets": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "array",
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "volumes": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/RawRunnerConfigInner"
      }
    },
    "RawRunnerConfigInner": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "format": "uint8",
          "default": 1,
          "maximum": 255,
          "minimum": 1
        },
        "cpus": {
          "type": "integer",
          "format": "uint8",
          "default": 1,
          "maximum": 255,
          "minimum": 1
        },
        "envs": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "envs_mode": {
          "$ref": "#/$defs/RunnerResolveMode",
          "default": "merge"
        },
        "image": {
          "type": "string"
        },
        "memory": {
          "type": "integer",
          "format": "uint32",
          "default": 512,
          "minimum": 1
        },
        "ports": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "integer",
            "format": "uint16",
            "maximum": 65535,
            "minimum": 0
          },
          "default": null
        },
        "ports_mode": {
          "$ref": "#/$defs/RunnerResolveMode",
          "default": "merge"
        },
        "secrets": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "array",
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "secrets_mode": {
          "$ref": "#/$defs/RunnerResolveMode",
          "default": "merge"
        },
        "volumes": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "volumes_mode": {
          "$ref": "#/$defs/RunnerResolveMode",
          "default": "merge"
        }
      },
      "required": [
        "image"
      ]
    },
    "RunnerResolveMode": {
      "type": "string",
      "enum": [
        "replace",
        "merge",
        "ignore"
      ]
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "bitbucket",
        "forgejo",
        "gitea",
        "github",
        "gitlab",
        "woodpecker"
      ]
    }
  }
}
